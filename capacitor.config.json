{
  "appId": "com.ducky.darkwing",
  "appName": "DARKWING",
  "webDir": "dist",
  "backgroundColor": "#0D0D1A",
  "android": {
    "minWebViewVersion": 60,
    "backgroundColor": "#0D0D1A"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0D0D1A",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0D0D1A"
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    }
  }
}
